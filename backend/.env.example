# Copy this file to .env and fill in your values
# Privacy Policy Grader - Environment Configuration

# -----------------------------------------------
# Google Gemini API Key
# Get yours at https://makersuite.google.com/app/apikey
# If left blank the app will run in DEMO MODE with mock LLM responses
# -----------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------
# Flask settings
# -----------------------------------------------
FLASK_DEBUG=False
FLASK_TESTING=False

# -----------------------------------------------
# Database
# SQLite by default; change to postgresql:// for production
# -----------------------------------------------
DATABASE_URL=sqlite:///privacy_grader.db

# -----------------------------------------------
# Gemini model settings
# -----------------------------------------------
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_TOKENS=8192
GEMINI_TEMPERATURE=0.2

# -----------------------------------------------
# Rate limiting (requests per minute per IP)
# -----------------------------------------------
RATE_LIMIT_PER_MIN=60

# -----------------------------------------------
# Scraping settings (seconds)
# -----------------------------------------------
SCRAPE_TIMEOUT=15
